import { NextResponse } from 'next/server';

const SYSTEM_PROMPT = `You are a senior technical recruiter with 15+ years of experience screening thousands of LinkedIn profiles and resumes. You're known for your brutal honesty and strategic insight.

You're about to simulate the real recruiter experience: scanning a profile in 10-20 seconds and forming snap judgments. Be specific, actionable, and psychologically sharp. Don't sugarcoat.

Analyze the provided profile text and return ONLY valid JSON (no markdown, no backticks) in this exact structure:

{
  "firstImpression": "A 2-3 sentence gut reaction. What hits you first? What's the vibe? Be honest and specific.",
  "clearElements": ["Array of 3-5 things that immediately communicate well"],
  "confusingElements": ["Array of 2-4 things that are unclear, vague, or raise questions"],
  "perceivedTarget": "What role/level/industry does this person APPEAR to be targeting based on how the profile reads (not what they might intend)",
  "skipTriggers": ["Array of 2-4 specific things that might cause a recruiter to move on to the next candidate"],
  "positioning": [
    {
      "issue": "Specific positioning problem",
      "fix": "Concrete, actionable recommendation"
    },
    {
      "issue": "Another positioning problem",
      "fix": "Another concrete fix"
    },
    {
      "issue": "Third issue if applicable",
      "fix": "Third fix"
    }
  ],
  "overallGrade": "A/B/C/D/F grade for recruiter-readiness",
  "oneLineSummary": "One sharp sentence summarizing what this profile needs most"
}`;

export async function POST(request) {
  try {
    const { profileText } = await request.json();

    if (!profileText || typeof profileText !== 'string' || profileText.trim().length === 0) {
      return NextResponse.json({ error: 'Profile text is required' }, { status: 400 });
    }

    // Limit input length to prevent abuse
    if (profileText.length > 10000) {
      return NextResponse.json({ error: 'Profile text too long (max 10,000 characters)' }, { status: 400 });
    }

    const apiKey = process.env.ANTHROPIC_API_KEY;
    if (!apiKey) {
      return NextResponse.json({ error: 'Server configuration error' }, { status: 500 });
    }

    const response = await fetch('https://api.anthropic.com/v1/messages', {
      method: 'POST',
      headers: {
        'Content-Type': 'application/json',
        'x-api-key': apiKey,
        'anthropic-version': '2023-06-01',
      },
      body: JSON.stringify({
        model: 'claude-sonnet-4-20250514',
        max_tokens: 1000,
        system: SYSTEM_PROMPT,
        messages: [
          {
            role: 'user',
            content: `Here is the LinkedIn profile text to analyze:\n\n${profileText}`,
          },
        ],
      }),
    });

    if (!response.ok) {
      const errText = await response.text();
      console.error('Anthropic API error:', response.status, errText);
      return NextResponse.json({ error: 'Analysis service unavailable' }, { status: 502 });
    }

    const data = await response.json();
    const text = data.content?.map((b) => b.text || '').filter(Boolean).join('');
    const cleaned = text.replace(/```json|```/g, '').trim();
    const result = JSON.parse(cleaned);

    return NextResponse.json(result);
  } catch (err) {
    console.error('Analysis error:', err);
    return NextResponse.json({ error: 'Analysis failed' }, { status: 500 });
  }
}
